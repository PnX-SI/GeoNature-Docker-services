# syntax=docker.io/docker/dockerfile:1.6

ARG GEONATURE_BACKEND_IMAGE="ghcr.io/pnx-si/geonature-backend-local:latest"
FROM ${GEONATURE_BACKEND_IMAGE}-dev as dev

ARG DOCKER_UID=1000
ARG DOCKER_GID=1000

WORKDIR /dist/geonature

RUN if echo "Creating user geonature with UID: ${UID}, GID: ${GID}" && groupadd -g ${GID} geonature && \
    useradd -m -u ${UID} -g geonature geonature; then echo "Created user geonature"; \
    else echo "User or group geonature already exists, continuing"; \
    fi

RUN rm -f geonature-*

COPY --chown=${DOCKER_UID}:${DOCKER_GUID} sources/GeoNature/backend/requirements-dev.txt .

# Delete when those dependency will be added to requirements-dev
RUN pip install uv
RUN --mount=type=cache,target=/root/.cache  uv pip install --system watchdog pytest pytest-flask pytest-benchmark pip-tools

COPY --chmod=755 /build/dev/dev_entrypoint.sh /
ENTRYPOINT ["/dev_entrypoint.sh"]

USER geonature